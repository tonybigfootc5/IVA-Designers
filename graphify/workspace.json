{
  "project": "IVA Web Platform",
  "brand": "IVA — Designer's Cult",
  "pipeline": ["Graphify", "GitHub", "Vercel"],
  "integrations": {
    "github": {
      "repository": "https://github.com/tonybigfootc5/IVA-Designers.git",
      "defaultBranch": "main",
      "status": "connected-locally"
    },
    "vercel": {
      "projectName": "iva-designers",
