    "graphify": {
      "workspace": "graphify/workspace.json",
      "status": "connected-in-repo"
    }
  },
  "stack": {
    "frontend": "Next.js 15 App Router",
    "language": "TypeScript",
    "styling": "Tailwind CSS",
