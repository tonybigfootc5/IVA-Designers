    { "id": "stage-2", "name": "Authentication & Commerce", "status": "in_progress" },
    { "id": "stage-3", "name": "Student Experience", "status": "planned" },
    { "id": "stage-4", "name": "Admin & Live Operations", "status": "in_progress" },
    { "id": "stage-5", "name": "Launch, Scale & Monitoring", "status": "planned" }
  ],
  "deployments": {
    "preview": "Vercel Preview",
    "production": "Vercel Production"
  },
  "links": {
    "repository": "https://github.com/tonybigfootc5/IVA-Designers.git",
    "healthEndpoint": "/api/health",
